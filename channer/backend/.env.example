# Channer Environment Configuration

# 应用环境: development | production
ENVIRONMENT=development

# 服务器配置
SERVER_ADDRESS=:8080

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=channer
DB_PASSWORD=channer
DB_NAME=channer
DB_SSLMODE=disable

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=channer-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h
